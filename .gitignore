# Dependencies (Vitest lands in WP1; the shipped app has none)
node_modules/

# Secrets — the YouTube API key never enters the repo
.env
.env.*
*.local
# Local dev convenience: your own key, pre-filled into the Live API field.
# Matches in any directory; never committed, never shipped.
config.local.js

# External / working notes (GPT dumps, scratch rationale) — not part of the repo
external-docs/
# Parked research notes — kept locally, out of the repo
Future/

# Claude Code personal settings (machine-local, not for the repo)
.claude/settings.local.json

# Editor / OS cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Test / build output — reports are generated on demand, never committed
coverage/
reports/
